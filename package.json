{
  "name": "thegamehour-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node scripts/generate-favicons.mjs && vite build && node scripts/copy-cms-to-dist.mjs",
    "cms:sync": "node scripts/copy-cms-to-dist.mjs",
    "cms:audit": "node scripts/audit-image-mappings.mjs",
    "cms:verify": "node --experimental-strip-types scripts/verify-cms-mapping.mjs",
    "cms:dev": "node scripts/copy-cms-to-dist.mjs && php -S localhost:8765 -t dist scripts/dev-router.php",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "assets:migrate": "node scripts/migrate-assets.mjs",
    "assets:og-public": "node scripts/generate-public-og.mjs",
    "assets:favicons": "node scripts/generate-favicons.mjs",
    "assets": "npm run assets:migrate && npm run assets:og-public && npm run assets:favicons"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
